# Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hartfordvapes"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxx"

# SendGrid (get from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@hartfordvapes.com"

# AWS S3 (for image uploads)
AWS_ACCESS_KEY_ID="xxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxx"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="hartfordvapes-images"

# App Config
NODE_ENV="development"
PORT=3001
CLIENT_URL="http://localhost:5174"
